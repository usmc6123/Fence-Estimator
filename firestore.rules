rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token != null && (
        request.auth.token.email == 'usmc6123@gmail.com' ||
        request.auth.token.email == 'bradens@lonestarfenceworks.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isEmployee() {
      return isSignedIn() && request.auth.token != null && request.auth.token.email != null && exists(/databases/$(database)/documents/employees/$(request.auth.token.email));
    }

    function getEmployeePermission() {
      return get(/databases/$(database)/documents/employees/$(request.auth.token.email)).data.permission;
    }

    function canEmployeeEdit() {
      return isEmployee() && getEmployeePermission() == 'Can Edit';
    }

    function isCompanyMember() {
      return isSignedIn() && (isAdmin() || isEmployee());
    }

    function canWriteData() {
      return isSignedIn() && (isAdmin() || canEmployeeEdit());
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Validation Helpers ---

    function isValidEstimate(data) {
      return data.companyId == 'lonestarfence'
        && data.id is string
        && (data.customerName == null || data.customerName is string)
        && (data.customerEmail == null || data.customerEmail is string);
    }

    function isValidBankAccount(data) {
      return data.companyId == 'lonestarfence'
        && data.name is string && data.name.size() <= 100
        && data.type in ['Checking', 'Savings', 'Credit Card']
        && data.balance is number;
    }

    function isValidTransaction(data) {
      return data.companyId == 'lonestarfence'
        && data.accountId is string
        && data.amount is number
        && data.type in ['Income', 'Expense']
        && data.status in ['Pending', 'Cleared', 'Reconciled'];
    }

    function isValidInventory(data) {
      return data.companyId == 'lonestarfence'
        && data.materialId is string
        && data.quantityInStock is number;
    }

    function isValidJournal(data) {
      return data.companyId == 'lonestarfence'
        && data.date is string
        && data.lines is list;
    }

    function isValidQuote(data) {
      return data.companyId == 'lonestarfence';
    }

    function isValidMaterial(data) {
      return data.companyId == 'lonestarfence'
        && data.id is string
        && data.name is string
        && data.cost is number;
    }

    function isValidExpense(data) {
      return data.companyId == 'lonestarfence'
        && data.amount is number
        && data.date is string
        && data.description is string;
    }

    function isValidSettings(data, settingId) {
      return (settingId == 'main' || settingId == 'scheduler' || data.id is string)
        && (data.ghlWebhookUrl == null || data.ghlWebhookUrl is string);
    }

    function isValidEmployee(data) {
      return (data.email == null || data.email is string)
        && (data.permission == null || data.permission in ['View Only', 'Can Edit']);
    }

    function isValidUserProfile(data) {
      return data.uid is string
        && data.tier in ['free', 'paid']
        && (data.email == null || data.email is string);
    }

    function isValidEvent(data) {
      return data.id is string
        && data.title is string
        && data.type in ['Job', 'Estimate', 'Blackout', 'Busy']
        && data.startDate is string;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || request.auth.token.email == resource.data.email);
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId || request.auth.token.email == incoming().email) && isValidUserProfile(incoming());
      allow update: if (isSignedIn() && (request.auth.uid == userId || request.auth.token.email == incoming().email) && isValidUserProfile(incoming()))
                      || isAdmin();
      allow delete: if isAdmin();

      match /estimates/{estimate} {
        allow read, write: if (isSignedIn() && (request.auth.uid == userId || request.auth.token.email == get(/databases/$(database)/documents/users/$(userId)).data.email)) || isAdmin();
      }
    }

    match /admins/{admin} {
      allow read, write: if (isSignedIn() && request.auth.uid == admin) || isAdmin();
    }

    match /employees/{email} {
      allow get, list: if isCompanyMember();
      allow create, update: if isAdmin() && isValidEmployee(incoming());
      allow delete: if isAdmin();
    }

    match /companySettings/{settingId} {
      allow get: if isCompanyMember() || settingId == 'main' || (isSignedIn() && request.auth.uid == settingId);
      allow list: if isCompanyMember();
      allow create, update: if (settingId == 'main' || settingId == 'scheduler' || canWriteData() || (isSignedIn() && request.auth.uid == settingId)) && isValidSettings(incoming(), settingId);
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow get, list: if isCompanyMember();
      allow create:    if canWriteData() && isValidExpense(incoming());
      allow update:    if canWriteData() && resource.data.companyId == 'lonestarfence' && isValidExpense(incoming());
      allow delete:    if canWriteData() && resource.data.companyId == 'lonestarfence';
    }

    match /estimates/{estimateId} {
      allow read:      if isCompanyMember() || (isSignedIn() && (resource == null || resource.data.clerkUserId == request.auth.uid || resource.data.userId == request.auth.uid || resource.data.customerEmail == request.auth.token.email));
      allow create:    if (canWriteData() || (incoming().isCustomerEstimate == true) || (isSignedIn() && (incoming().clerkUserId == request.auth.uid || incoming().userId == request.auth.uid || incoming().customerEmail == request.auth.token.email))) && isValidEstimate(incoming());
      allow update:    if (canWriteData() && resource.data.companyId == 'lonestarfence' && isValidEstimate(incoming())) || (isSignedIn() && (resource.data.clerkUserId == request.auth.uid || resource.data.userId == request.auth.uid || resource.data.customerEmail == request.auth.token.email) && isValidEstimate(incoming()));
      allow delete:    if (canWriteData() && resource.data.companyId == 'lonestarfence') || (isSignedIn() && (resource.data.clerkUserId == request.auth.uid || resource.data.userId == request.auth.uid || resource.data.customerEmail == request.auth.token.email));
    }

    match /bankAccounts/{accountId} {
      allow get, list: if isCompanyMember();
      allow create:    if canWriteData() && isValidBankAccount(incoming());
      allow update:    if canWriteData() && resource.data.companyId == 'lonestarfence' && isValidBankAccount(incoming());
      allow delete:    if canWriteData() && resource.data.companyId == 'lonestarfence';
    }

    match /transactions/{transactionId} {
      allow get, list: if isCompanyMember();
      allow create:    if canWriteData() && isValidTransaction(incoming());
      allow update:    if canWriteData() && resource.data.companyId == 'lonestarfence' && isValidTransaction(incoming());
      allow delete:    if canWriteData() && resource.data.companyId == 'lonestarfence';
    }

    match /inventory/{inventoryId} {
      allow get, list: if isCompanyMember();
      allow create:    if canWriteData() && isValidInventory(incoming());
      allow update:    if canWriteData() && resource.data.companyId == 'lonestarfence' && isValidInventory(incoming());
      allow delete:    if canWriteData() && resource.data.companyId == 'lonestarfence';
    }

    match /journalEntries/{entryId} {
      allow get, list: if isCompanyMember();
      allow create:    if canWriteData() && isValidJournal(incoming());
      allow update:    if canWriteData() && resource.data.companyId == 'lonestarfence' && isValidJournal(incoming());
      allow delete:    if canWriteData() && resource.data.companyId == 'lonestarfence';
    }

    match /quotes/{quoteId} {
      allow get, list: if isCompanyMember();
      allow create:    if canWriteData() && isValidQuote(incoming());
      allow update:    if canWriteData() && resource.data.companyId == 'lonestarfence' && isValidQuote(incoming());
      allow delete:    if canWriteData() && resource.data.companyId == 'lonestarfence';
    }

    match /materials/{materialId} {
      allow get, list: if true;
      allow create:    if canWriteData() && isValidMaterial(incoming());
      allow update:    if canWriteData() && resource.data.companyId == 'lonestarfence' && isValidMaterial(incoming());
      allow delete:    if canWriteData() && resource.data.companyId == 'lonestarfence';
    }

    match /customPhotos/{photoId} {
      allow get, list: if true;
      allow create, update: if canWriteData();
      allow delete:         if canWriteData();
    }

    match /schedule_events/{eventId} {
      allow get, list: if isCompanyMember();
      allow create:    if canWriteData() && isValidEvent(incoming());
      allow update:    if canWriteData() && isValidEvent(incoming());
      allow delete:    if canWriteData();
    }

    match /ghlContactSyncTraces/{traceId} {
      allow read, write: if isCompanyMember();
    }
  }
}
