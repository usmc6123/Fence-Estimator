rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isCompanyMember() {
      return isSignedIn();
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidEstimate(data) {
      return data.companyId == 'lonestarfence'
        && data.id is string
        && (data.customerName == null || data.customerName is string)
        && (data.customerEmail == null || data.customerEmail is string);
    }

    function isValidBankAccount(data) {
      return data.companyId == 'lonestarfence'
        && data.name is string && data.name.size() <= 100
        && data.type in ['Checking', 'Savings', 'Credit Card']
        && data.balance is number;
    }

    function isValidTransaction(data) {
      return data.companyId == 'lonestarfence'
        && data.accountId is string
        && data.amount is number
        && data.type in ['Income', 'Expense']
        && data.status in ['Pending', 'Cleared', 'Reconciled'];
    }

    function isValidInventory(data) {
      return data.companyId == 'lonestarfence'
        && data.materialId is string
        && data.quantityInStock is number;
    }

    function isValidJournal(data) {
      return data.companyId == 'lonestarfence'
        && data.date is string
        && data.lines is list;
    }

    function isValidQuote(data) {
      return data.companyId == 'lonestarfence';
    }

    function isValidMaterial(data) {
      return data.companyId == 'lonestarfence'
        && data.id is string
        && data.name is string
        && data.cost is number;
    }

    function isValidSettings(data) {
      return data.id is string
        && (data.ghlWebhookUrl == null || data.ghlWebhookUrl is string);
    }

    // --- Collection Routes ---

    match /companySettings/{settingId} {
      allow get, list: if isCompanyMember();
      allow create, update: if isCompanyMember() && isValidSettings(incoming());
      allow delete: if isCompanyMember();
    }

    match /estimates/{estimateId} {
      allow get, list: if isCompanyMember() && resource.data.companyId == 'lonestarfence';
      allow create:    if isSignedIn() && isValidEstimate(incoming());
      allow update:    if isCompanyMember() && existing().companyId == 'lonestarfence' && isValidEstimate(incoming());
      allow delete:    if isCompanyMember() && existing().companyId == 'lonestarfence';
    }

    match /bankAccounts/{accountId} {
      allow get, list: if isCompanyMember() && resource.data.companyId == 'lonestarfence';
      allow create:    if isSignedIn() && isValidBankAccount(incoming());
      allow update:    if isCompanyMember() && existing().companyId == 'lonestarfence' && isValidBankAccount(incoming());
      allow delete:    if isCompanyMember() && existing().companyId == 'lonestarfence';
    }

    match /transactions/{transactionId} {
      allow get, list: if isCompanyMember() && resource.data.companyId == 'lonestarfence';
      allow create:    if isSignedIn() && isValidTransaction(incoming());
      allow update:    if isCompanyMember() && existing().companyId == 'lonestarfence' && isValidTransaction(incoming());
      allow delete:    if isCompanyMember() && existing().companyId == 'lonestarfence';
    }

    match /inventory/{inventoryId} {
      allow get, list: if isCompanyMember() && resource.data.companyId == 'lonestarfence';
      allow create:    if isSignedIn() && isValidInventory(incoming());
      allow update:    if isCompanyMember() && existing().companyId == 'lonestarfence' && isValidInventory(incoming());
      allow delete:    if isCompanyMember() && existing().companyId == 'lonestarfence';
    }

    match /journalEntries/{entryId} {
      allow get, list: if isCompanyMember() && resource.data.companyId == 'lonestarfence';
      allow create:    if isSignedIn() && isValidJournal(incoming());
      allow update:    if isCompanyMember() && existing().companyId == 'lonestarfence' && isValidJournal(incoming());
      allow delete:    if isCompanyMember() && existing().companyId == 'lonestarfence';
    }

    match /quotes/{quoteId} {
      allow get, list: if isCompanyMember() && resource.data.companyId == 'lonestarfence';
      allow create:    if isSignedIn() && isValidQuote(incoming());
      allow update:    if isCompanyMember() && existing().companyId == 'lonestarfence' && isValidQuote(incoming());
      allow delete:    if isCompanyMember() && existing().companyId == 'lonestarfence';
    }

    match /materials/{materialId} {
      allow get, list: if isCompanyMember() && resource.data.companyId == 'lonestarfence';
      allow create:    if isSignedIn() && isValidMaterial(incoming());
      allow update:    if isCompanyMember() && existing().companyId == 'lonestarfence' && isValidMaterial(incoming());
      allow delete:    if isCompanyMember() && existing().companyId == 'lonestarfence';
    }
  }
}
