rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /quotes/{allPaths=**} {
      // Allow read for any authenticated user
      allow read: if request.auth != null;
      
      // Allow write (create, update, delete) for any authenticated user
      // with size and content type constraints for uploads/updates
      allow write: if request.auth != null
                   && (request.method == 'delete' || (
                     request.resource.size < 25 * 1024 * 1024 // 25MB limit
                     && request.resource.contentType.matches('application/pdf|image/jpeg|image/png')
                   ));
    }

    // Default deny for all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
