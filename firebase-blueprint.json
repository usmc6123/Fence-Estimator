{
  "entities": {
    "Estimate": {
      "title": "Estimate",
      "description": "A fence project estimate",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerAddress": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "runs": { "type": "array" },
        "laborRates": { "type": "object" },
        "markupPercentage": { "type": "number" },
        "taxPercentage": { "type": "number" },
        "wastePercentage": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "userId"]
    },
    "BankAccount": {
      "title": "Bank Account",
      "description": "Linked bank account information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Checking", "Savings", "Credit Card"] },
        "balance": { "type": "number" },
        "institutionName": { "type": "string" },
        "lastSync": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "type", "userId"]
    },
    "BankTransaction": {
      "title": "Bank Transaction",
      "description": "Financial transaction synced from bank or entered manually",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "accountId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["Income", "Expense"] },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Cleared", "Reconciled"] },
        "estimateId": { "type": "string" },
        "receiptUrl": { "type": "string" },
        "receiptName": { "type": "string" },
        "notes": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "accountId", "date", "amount", "type", "userId"]
    },
    "InventoryStock": {
      "title": "Inventory Stock",
      "description": "Track stock levels for materials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "materialId": { "type": "string" },
        "quantityInStock": { "type": "number" },
        "minStockLevel": { "type": "number" },
        "averageCost": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "materialId", "userId"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "Manual accounting adjustment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "lines": { "type": "array" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "userId"]
    },
    "Material": {
      "title": "Material",
      "description": "A material item in the library",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "cost": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "aliases": { "type": "array" }
      },
      "required": ["id", "companyId", "name", "category", "unit", "cost"]
    },
    "Quote": {
      "title": "Supplier Quote",
      "description": "A quote document from a supplier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "supplierName": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" }
      },
      "required": ["id", "companyId", "supplierName", "totalAmount"]
    },
    "CompanySettings": {
      "title": "Company Settings",
      "description": "Global company settings and integrations",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "companyEmail": { "type": "string" },
        "companyPhone": { "type": "string" },
        "companyWebsite": { "type": "string" },
        "companyLogo": { "type": "string" },
        "smtpHost": { "type": "string" },
        "smtpPort": { "type": "number" },
        "smtpSecureType": { "type": "string", "enum": ["SSL/TLS", "STARTTLS", "None"] },
        "smtpUsername": { "type": "string" },
        "smtpPassword": { "type": "string" },
        "fromEmail": { "type": "string" },
        "fromName": { "type": "string" },
        "replyToEmail": { "type": "string" },
        "gohighlevelWebhookUrl": { "type": "string" },
        "ghlWebhookUrl": { "type": "string" },
        "googleReviewLink": { "type": "string" },
        "estimateEmailSubject": { "type": "string" },
        "estimateEmailBody": { "type": "string" },
        "estimateAcceptedMessage": { "type": "string" },
        "estimateDeclinedMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "Employee": {
      "title": "Employee",
      "description": "A company employee with portal credentials and permissions",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "permission": { "type": "string", "enum": ["View Only", "Can Edit"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "password": { "type": "string" }
      },
      "required": ["email", "permission"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user's account and subscription state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "tier": { "type": "string", "enum": ["free", "paid"] },
        "passwordHash": { "type": "string" },
        "stripeCustomerId": { "type": "string" },
        "stripeSubscriptionId": { "type": "string" },
        "nextBillingDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "tier", "createdAt"]
    },
    "SupplierQuoteSnapshot": {
      "title": "Supplier Quote Snapshot",
      "description": "Immutable historical snapshot of a supplier quote",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "quoteNumber": { "type": "string" },
        "quoteDate": { "type": "string" },
        "effectiveDate": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" },
        "documentUrl": { "type": "string" },
        "documentPath": { "type": "string" },
        "originalFilename": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "superseded", "draft"] },
        "lineItems": { "type": "array" },
        "comparisonSummary": { "type": "object" },
        "previousSnapshotId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "supplierId", "supplierName", "uploadedAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User subscription and account tier info"
    },
    "/estimates/{estimateId}": {
      "schema": "Estimate",
      "description": "Collection of fence estimates"
    },
    "/bankAccounts/{accountId}": {
      "schema": "BankAccount",
      "description": "User bank accounts"
    },
    "/transactions/{transactionId}": {
      "schema": "BankTransaction",
      "description": "Bank and manual transactions"
    },
    "/inventory/{inventoryId}": {
      "schema": "InventoryStock",
      "description": "Material inventory tracking"
    },
    "/journalEntries/{entryId}": {
      "schema": "JournalEntry",
      "description": "Accounting journal entries"
    },
    "/materials/{materialId}": {
      "schema": "Material",
      "description": "Company material library"
    },
    "/quotes/{quoteId}": {
      "schema": "Quote",
      "description": "Supplier quotes"
    },
    "/supplierQuoteSnapshots/{snapshotId}": {
      "schema": "SupplierQuoteSnapshot",
      "description": "Historical snapshots of supplier quotes"
    },
    "/companySettings/{settingId}": {
      "schema": "CompanySettings",
      "description": "Global settings for the company"
    },
    "/employees/{email}": {
      "schema": "Employee",
      "description": "Registered company employees"
    }
  }
}
